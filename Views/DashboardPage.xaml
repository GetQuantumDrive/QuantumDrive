<Page
    x:Class="quantum_drive.Views.DashboardPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:models="using:quantum_drive.Models"
    mc:Ignorable="d"
    Background="Transparent">

    <ScrollViewer>
        <StackPanel Padding="40,36" Spacing="28" MaxWidth="720">

            <!-- Header -->
            <Grid>
                <StackPanel Orientation="Horizontal" Spacing="14" VerticalAlignment="Center">
                    <Image Source="ms-appx:///Assets/Square44x44Logo.scale-200.png"
                           Width="36" Height="36"/>
                    <TextBlock Text="QuantumDrive"
                               FontSize="24" FontWeight="SemiBold"
                               VerticalAlignment="Center"/>
                </StackPanel>
                <Button HorizontalAlignment="Right" VerticalAlignment="Center"
                        Command="{x:Bind ViewModel.NavigateToSettingsCommand}">
                    <FontIcon Glyph="&#xE115;" FontSize="18"/>
                </Button>
            </Grid>

            <!-- Notification -->
            <TextBlock Text="{x:Bind ViewModel.NotificationMessage, Mode=OneWay}"
                       FontSize="13"
                       Opacity="{x:Bind ViewModel.NotificationOpacity, Mode=OneWay}"
                       Foreground="{x:Bind ViewModel.NotificationForeground, Mode=OneWay}"
                       IsTextSelectionEnabled="False">
                <TextBlock.OpacityTransition>
                    <ScalarTransition Duration="0:0:0.3"/>
                </TextBlock.OpacityTransition>
            </TextBlock>

            <!-- Virtual Drive -->
            <Border Background="{ThemeResource AcrylicBackgroundFillColorDefaultBrush}"
                    CornerRadius="12" Padding="28">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" VerticalAlignment="Center" Spacing="6">
                        <TextBlock Text="{x:Bind ViewModel.DriveLabel, Mode=OneWay}"
                                   FontSize="20" FontWeight="SemiBold"/>
                        <Grid Height="20">
                            <TextBlock Text="Post-quantum encrypted virtual drive"
                                       FontSize="13" Opacity="0.5"
                                       VerticalAlignment="Center"
                                       Visibility="{x:Bind ViewModel.IsDriveMounting, Mode=OneWay, Converter={StaticResource InvertBoolToVisibilityConverter}}"/>
                            <StackPanel Orientation="Horizontal" Spacing="8"
                                        Visibility="{x:Bind ViewModel.IsDriveMounting, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                                <ProgressRing IsActive="True" Width="16" Height="16"/>
                                <TextBlock Text="Configuring drive..." FontSize="13" Opacity="0.5" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Grid>
                        <HyperlinkButton Padding="0" Height="Auto"
                                         Command="{x:Bind ViewModel.OpenVirtualDriveCommand}"
                                         Visibility="{x:Bind ViewModel.IsDriveMounted, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <FontIcon Glyph="&#xED25;" FontSize="12"/>
                                <TextBlock Text="Open in Explorer" FontSize="13"/>
                            </StackPanel>
                        </HyperlinkButton>
                    </StackPanel>

                    <ToggleSwitch Grid.Column="1"
                                  IsOn="{x:Bind ViewModel.IsDriveMounted, Mode=TwoWay}"
                                  IsEnabled="{x:Bind ViewModel.IsDriveMounting, Mode=OneWay, Converter={StaticResource InvertBoolConverter}}"
                                  VerticalAlignment="Center"/>
                </Grid>
            </Border>

            <!-- Vault List -->
            <StackPanel Spacing="8">
                <Grid>
                    <TextBlock Text="Vaults" FontSize="18" FontWeight="SemiBold"
                               VerticalAlignment="Center"/>
                    <DropDownButton HorizontalAlignment="Right">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <FontIcon Glyph="&#xE710;" FontSize="14"/>
                            <TextBlock Text="Add Vault"/>
                        </StackPanel>
                        <DropDownButton.Flyout>
                            <MenuFlyout Placement="BottomEdgeAlignedRight">
                                <MenuFlyoutItem Text="Create New Vault" Click="CreateNewVault_Click">
                                    <MenuFlyoutItem.Icon>
                                        <FontIcon Glyph="&#xE710;"/>
                                    </MenuFlyoutItem.Icon>
                                </MenuFlyoutItem>
                                <MenuFlyoutItem Text="Add Existing Vault" Click="AddExistingVault_Click">
                                    <MenuFlyoutItem.Icon>
                                        <FontIcon Glyph="&#xED25;"/>
                                    </MenuFlyoutItem.Icon>
                                </MenuFlyoutItem>
                            </MenuFlyout>
                        </DropDownButton.Flyout>
                    </DropDownButton>
                </Grid>

                <ItemsRepeater ItemsSource="{x:Bind ViewModel.VaultList}">
                    <ItemsRepeater.Layout>
                        <StackLayout Spacing="8"/>
                    </ItemsRepeater.Layout>
                    <ItemsRepeater.ItemTemplate>
                        <DataTemplate x:DataType="models:VaultStatusItem">
                            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                    CornerRadius="10" Padding="20"
                                    Tapped="VaultCard_Tapped">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <FontIcon Grid.Column="0" Glyph="{x:Bind IsUnlocked, Converter={StaticResource BoolToLockGlyphConverter}}"
                                              FontSize="24" VerticalAlignment="Center" Margin="0,0,16,0"
                                              Foreground="{x:Bind IsUnlocked, Converter={StaticResource BoolToLockColorConverter}}"/>

                                    <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="2"
                                                Opacity="{x:Bind IsUnlocked, Converter={StaticResource BoolToOpacityConverter}}">
                                        <TextBlock Text="{x:Bind Name}" FontWeight="SemiBold" FontSize="15"/>
                                        <TextBlock FontSize="12" Opacity="0.5">
                                            <Run Text="{x:Bind FileCount}"/>
                                            <Run Text="files"/>
                                            <Run Text=" · "/>
                                            <Run Text="{x:Bind SizeLabel}"/>
                                        </TextBlock>
                                        <HyperlinkButton Padding="0" Height="Auto"
                                                         Tag="{x:Bind FolderPath}"
                                                         Click="OpenVaultFolder_Click"
                                                         ToolTipService.ToolTip="{x:Bind FolderPath}">
                                            <TextBlock Text="{x:Bind FolderPath}" FontSize="11" Opacity="0.4"
                                                       TextTrimming="CharacterEllipsis" MaxWidth="300"/>
                                        </HyperlinkButton>
                                    </StackPanel>

                                    <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="4"
                                                VerticalAlignment="Center">
                                        <Button Click="UnlockVault_Click" Tag="{x:Bind Id}"
                                                Style="{StaticResource AccentButtonStyle}"
                                                Visibility="{x:Bind IsUnlocked, Converter={StaticResource InvertBoolToVisibilityConverter}}"
                                                ToolTipService.ToolTip="Unlock vault">
                                            <StackPanel Orientation="Horizontal" Spacing="6">
                                                <FontIcon Glyph="&#xE785;" FontSize="14"/>
                                                <TextBlock Text="Unlock"/>
                                            </StackPanel>
                                        </Button>
                                        <Button Click="DisconnectVault_Click" Tag="{x:Bind Id}"
                                                Visibility="{x:Bind IsUnlocked, Converter={StaticResource BoolToVisibilityConverter}}"
                                                ToolTipService.ToolTip="Lock vault">
                                            <FontIcon Glyph="&#xE72E;" FontSize="14"/>
                                        </Button>
                                        <Button Click="RemoveVault_Click" Tag="{x:Bind Id}"
                                                ToolTipService.ToolTip="Remove vault from list">
                                            <FontIcon Glyph="&#xE74D;" FontSize="14"/>
                                        </Button>
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsRepeater.ItemTemplate>
                </ItemsRepeater>
            </StackPanel>

            <!-- Support QuantumDrive -->
            <HyperlinkButton Command="{x:Bind ViewModel.OpenDonatePageCommand}"
                             Padding="0" HorizontalAlignment="Center" Opacity="0.45">
                <TextBlock FontSize="12">
                    QuantumDrive is free. &#x2615; Support development &#x2192;
                </TextBlock>
            </HyperlinkButton>
        </StackPanel>
    </ScrollViewer>
</Page>
