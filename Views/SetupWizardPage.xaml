<Page
    x:Class="quantum_drive.Views.SetupWizardPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="Transparent">

    <Page.Resources>
        <!-- Key icon pulse animation -->
        <Storyboard x:Name="KeyPulseAnimation" RepeatBehavior="Forever">
            <DoubleAnimation Storyboard.TargetName="KeyIconScale"
                             Storyboard.TargetProperty="ScaleX"
                             From="1.0" To="1.1" Duration="0:0:1" AutoReverse="True">
                <DoubleAnimation.EasingFunction><SineEase EasingMode="EaseInOut"/></DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetName="KeyIconScale"
                             Storyboard.TargetProperty="ScaleY"
                             From="1.0" To="1.1" Duration="0:0:1" AutoReverse="True">
                <DoubleAnimation.EasingFunction><SineEase EasingMode="EaseInOut"/></DoubleAnimation.EasingFunction>
            </DoubleAnimation>
        </Storyboard>
        <Storyboard x:Name="KeyFadeInAnimation">
            <DoubleAnimation Storyboard.TargetName="KeyIcon"
                             Storyboard.TargetProperty="Opacity"
                             From="0" To="1" Duration="0:0:1">
                <DoubleAnimation.EasingFunction><SineEase EasingMode="EaseOut"/></DoubleAnimation.EasingFunction>
            </DoubleAnimation>
        </Storyboard>
    </Page.Resources>

    <ScrollViewer>
        <Grid Padding="48" HorizontalAlignment="Center" VerticalAlignment="Center" MaxWidth="560">
            <StackPanel Spacing="32">

                <!-- Step Indicator -->
                <PipsPager NumberOfPages="4"
                           SelectedPageIndex="{x:Bind ViewModel.CurrentStep, Mode=OneWay}"
                           HorizontalAlignment="Center"
                           IsEnabled="False"/>

                <!-- ════════════ STEP 0: Welcome ════════════ -->
                <StackPanel Spacing="20"
                            Visibility="{x:Bind ViewModel.CurrentStep, Mode=OneWay, Converter={StaticResource StepToVisibilityConverter}, ConverterParameter=0}">

                    <!-- App Logo -->
                    <Image x:Name="KeyIcon"
                           Source="ms-appx:///Assets/Square150x150Logo.scale-200.png"
                           Width="80" Height="80" Opacity="0"
                           HorizontalAlignment="Center"
                           RenderTransformOrigin="0.5,0.5">
                        <Image.RenderTransform>
                            <ScaleTransform x:Name="KeyIconScale"/>
                        </Image.RenderTransform>
                    </Image>

                    <TextBlock Text="Welcome to QuantumDrive"
                               FontSize="32" FontWeight="Bold"
                               HorizontalAlignment="Center"
                               Foreground="{StaticResource QuantumVioletBrush}"/>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Spacing="8">
                        <TextBlock Text="Post-Quantum Encryption for Your Files"
                                   FontSize="16" Opacity="0.8"/>
                        <Border Background="{StaticResource QuantumVioletBrush}" CornerRadius="4" Padding="8,2">
                            <TextBlock Text="PUBLIC BETA" FontSize="11" FontWeight="SemiBold"
                                       Foreground="White"/>
                        </Border>
                    </StackPanel>

                    <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                            BorderThickness="1" CornerRadius="8" Padding="24">
                        <StackPanel Spacing="12">
                            <TextBlock Text="QuantumDrive uses Zero-Knowledge Architecture:"
                                       FontWeight="SemiBold" TextWrapping="Wrap"/>

                            <StackPanel Spacing="6">
                                <TextBlock Text="&#x2022; Your password never leaves this device" TextWrapping="Wrap"/>
                                <TextBlock Text="&#x2022; We cannot recover your password if lost" TextWrapping="Wrap"/>
                                <TextBlock Text="&#x2022; Even we cannot decrypt your files" TextWrapping="Wrap"/>
                            </StackPanel>

                            <TextBlock Text="Post-Quantum Encryption: ML-KEM-1024 + AES-256-GCM"
                                       FontWeight="SemiBold" Opacity="0.8" Margin="0,8,0,0"/>

                            <StackPanel Spacing="4">
                                <TextBlock Text="&#x2713; End-to-end encryption" Foreground="{StaticResource QuantumVioletBrush}"/>
                                <TextBlock Text="&#x2713; Post-quantum secure" Foreground="{StaticResource QuantumVioletBrush}"/>
                                <TextBlock Text="&#x2713; Unlimited files · 1 vault free" Foreground="{StaticResource QuantumVioletBrush}"/>
                                <TextBlock Text="&#x2713; Open-source security" Foreground="{StaticResource QuantumVioletBrush}"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- Terms & Conditions -->
                    <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                            BorderThickness="1" CornerRadius="8" Padding="24">
                        <StackPanel Spacing="12">
                            <TextBlock Text="Terms &amp; Conditions" FontWeight="SemiBold"/>
                            <ScrollViewer MaxHeight="160" Padding="0,0,8,0">
                                <TextBlock TextWrapping="Wrap" FontSize="12" Opacity="0.7" LineHeight="18">
                                    <Run FontWeight="SemiBold">Public Beta Notice</Run>
                                    <LineBreak/>
                                    QuantumDrive is currently in public beta. Features may change, and bugs may occur. Use at your own discretion.
                                    <LineBreak/><LineBreak/>
                                    <Run FontWeight="SemiBold">Disclaimer of Warranty</Run>
                                    <LineBreak/>
                                    This software is provided "as is", without warranty of any kind, express or implied, including but not limited to the warranties of merchantability, fitness for a particular purpose, and non-infringement.
                                    <LineBreak/><LineBreak/>
                                    <Run FontWeight="SemiBold">Limitation of Liability</Run>
                                    <LineBreak/>
                                    In no event shall the authors or copyright holders be liable for any claim, damages, or other liability, whether in an action of contract, tort, or otherwise, arising from, out of, or in connection with the software or the use or other dealings in the software. This includes, but is not limited to, any loss of data, loss of profits, or any indirect, incidental, special, or consequential damages.
                                    <LineBreak/><LineBreak/>
                                    <Run FontWeight="SemiBold">Data Responsibility</Run>
                                    <LineBreak/>
                                    You are solely responsible for maintaining backups of your data. QuantumDrive uses zero-knowledge encryption — if you lose your master password and recovery kit, your data cannot be recovered by anyone, including the developers.
                                    <LineBreak/><LineBreak/>
                                    By proceeding, you acknowledge that you have read and agree to these terms.
                                </TextBlock>
                            </ScrollViewer>
                            <CheckBox Content="I accept the Terms &amp; Conditions"
                                      IsChecked="{x:Bind ViewModel.HasAcceptedTerms, Mode=TwoWay}"/>
                        </StackPanel>
                    </Border>

                    <Button Content="Get Started"
                            HorizontalAlignment="Stretch"
                            Style="{StaticResource AccentButtonStyle}"
                            Command="{x:Bind ViewModel.NextStepCommand}"
                            IsEnabled="{x:Bind ViewModel.CanGetStarted, Mode=OneWay}"/>

                    <Button Content="Cancel"
                            HorizontalAlignment="Stretch"
                            Command="{x:Bind ViewModel.CancelSetupCommand}"/>

                    <HyperlinkButton Content="I already have a vault"
                                     HorizontalAlignment="Center"
                                     Click="ImportExistingVault_Click"/>
                </StackPanel>

                <!-- ════════════ STEP 1: Storage Selection ════════════ -->
                <StackPanel Spacing="20"
                            Visibility="{x:Bind ViewModel.CurrentStep, Mode=OneWay, Converter={StaticResource StepToVisibilityConverter}, ConverterParameter=1}">

                    <TextBlock Text="Choose Your Storage"
                               FontSize="24" FontWeight="Bold"
                               Foreground="{StaticResource QuantumVioletBrush}"/>

                    <TextBlock Text="Where should QuantumDrive store your encrypted files?"
                               TextWrapping="Wrap" Opacity="0.7"/>

                    <!-- Provider cards: 2x2 grid -->
                    <Grid ColumnSpacing="12" RowSpacing="12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- Local Folder -->
                        <Button Grid.Row="0" Grid.Column="0"
                                HorizontalAlignment="Stretch" HorizontalContentAlignment="Stretch"
                                Padding="0" Background="Transparent" BorderThickness="0"
                                Command="{x:Bind ViewModel.SelectBackendCommand}"
                                CommandParameter="local">
                            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                    BorderThickness="1" CornerRadius="8" Padding="16">
                                <StackPanel Spacing="6" HorizontalAlignment="Center">
                                    <Grid>
                                        <FontIcon Glyph="&#xE8B7;" FontSize="28" HorizontalAlignment="Center"/>
                                        <FontIcon Glyph="&#xE73E;" FontSize="14"
                                                  Foreground="{StaticResource QuantumVioletBrush}"
                                                  HorizontalAlignment="Right" VerticalAlignment="Top"
                                                  Visibility="{x:Bind ViewModel.IsLocalBackend, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}"/>
                                    </Grid>
                                    <TextBlock Text="Local Folder" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                                    <TextBlock Text="Stored on this device" FontSize="11" Opacity="0.7"
                                               TextWrapping="Wrap" HorizontalAlignment="Center" TextAlignment="Center"/>
                                </StackPanel>
                            </Border>
                        </Button>

                        <!-- Google Drive -->
                        <Button Grid.Row="0" Grid.Column="1"
                                HorizontalAlignment="Stretch" HorizontalContentAlignment="Stretch"
                                Padding="0" Background="Transparent" BorderThickness="0"
                                Command="{x:Bind ViewModel.SelectBackendCommand}"
                                CommandParameter="google-drive">
                            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                    BorderThickness="1" CornerRadius="8" Padding="16">
                                <StackPanel Spacing="6" HorizontalAlignment="Center">
                                    <Grid>
                                        <FontIcon Glyph="&#xE753;" FontSize="28" HorizontalAlignment="Center"/>
                                        <FontIcon Glyph="&#xE73E;" FontSize="14"
                                                  Foreground="{StaticResource QuantumVioletBrush}"
                                                  HorizontalAlignment="Right" VerticalAlignment="Top"
                                                  Visibility="{x:Bind ViewModel.IsGoogleDriveBackend, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}"/>
                                    </Grid>
                                    <TextBlock Text="Google Drive" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                                    <TextBlock Text="Sync to your Drive" FontSize="11" Opacity="0.7"
                                               TextWrapping="Wrap" HorizontalAlignment="Center" TextAlignment="Center"/>
                                </StackPanel>
                            </Border>
                        </Button>

                        <!-- Dropbox -->
                        <Button Grid.Row="1" Grid.Column="0"
                                HorizontalAlignment="Stretch" HorizontalContentAlignment="Stretch"
                                Padding="0" Background="Transparent" BorderThickness="0"
                                Command="{x:Bind ViewModel.SelectBackendCommand}"
                                CommandParameter="dropbox">
                            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                    BorderThickness="1" CornerRadius="8" Padding="16">
                                <StackPanel Spacing="6" HorizontalAlignment="Center">
                                    <Grid>
                                        <FontIcon Glyph="&#xE8F1;" FontSize="28" HorizontalAlignment="Center"/>
                                        <FontIcon Glyph="&#xE73E;" FontSize="14"
                                                  Foreground="{StaticResource QuantumVioletBrush}"
                                                  HorizontalAlignment="Right" VerticalAlignment="Top"
                                                  Visibility="{x:Bind ViewModel.IsDropboxBackend, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}"/>
                                    </Grid>
                                    <TextBlock Text="Dropbox" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                                    <TextBlock Text="Sync to your Dropbox" FontSize="11" Opacity="0.7"
                                               TextWrapping="Wrap" HorizontalAlignment="Center" TextAlignment="Center"/>
                                </StackPanel>
                            </Border>
                        </Button>

                        <!-- OneDrive -->
                        <Button Grid.Row="1" Grid.Column="1"
                                HorizontalAlignment="Stretch" HorizontalContentAlignment="Stretch"
                                Padding="0" Background="Transparent" BorderThickness="0"
                                Command="{x:Bind ViewModel.SelectBackendCommand}"
                                CommandParameter="onedrive">
                            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                    BorderThickness="1" CornerRadius="8" Padding="16">
                                <StackPanel Spacing="6" HorizontalAlignment="Center">
                                    <Grid>
                                        <FontIcon Glyph="&#xE753;" FontSize="28" HorizontalAlignment="Center"/>
                                        <FontIcon Glyph="&#xE73E;" FontSize="14"
                                                  Foreground="{StaticResource QuantumVioletBrush}"
                                                  HorizontalAlignment="Right" VerticalAlignment="Top"
                                                  Visibility="{x:Bind ViewModel.IsOneDriveBackend, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}"/>
                                    </Grid>
                                    <TextBlock Text="OneDrive" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                                    <TextBlock Text="Sync to OneDrive" FontSize="11" Opacity="0.7"
                                               TextWrapping="Wrap" HorizontalAlignment="Center" TextAlignment="Center"/>
                                </StackPanel>
                            </Border>
                        </Button>
                    </Grid>

                    <!-- Cloud OAuth section — shown when a cloud provider is selected -->
                    <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                            BorderThickness="1" CornerRadius="8" Padding="16"
                            Visibility="{x:Bind ViewModel.IsLocalBackend, Mode=OneWay, Converter={StaticResource InvertBoolToVisibilityConverter}}">
                        <StackPanel Spacing="12">
                            <TextBlock Text="Sign in to your account" FontWeight="SemiBold"/>
                            <Button Content="Connect Account"
                                    Command="{x:Bind ViewModel.ConnectCloudAccountCommand}"
                                    IsEnabled="{x:Bind ViewModel.IsAuthorizingCloud, Mode=OneWay, Converter={StaticResource InvertBoolConverter}}"/>
                            <ProgressRing IsActive="{x:Bind ViewModel.IsAuthorizingCloud, Mode=OneWay}"
                                          Width="24" Height="24" HorizontalAlignment="Left"/>
                            <!-- Connected confirmation -->
                            <StackPanel Orientation="Horizontal" Spacing="6"
                                        Visibility="{x:Bind ViewModel.ConnectedAccountLabel, Mode=OneWay, Converter={StaticResource StringToVisibilityConverter}}">
                                <FontIcon Glyph="&#xE73E;" FontSize="14"
                                          Foreground="{StaticResource QuantumVioletBrush}"/>
                                <TextBlock Text="{x:Bind ViewModel.ConnectedAccountLabel, Mode=OneWay}"
                                           Foreground="{StaticResource QuantumVioletBrush}"/>
                            </StackPanel>
                            <!-- Auth error -->
                            <TextBlock Text="{x:Bind ViewModel.CloudAuthError, Mode=OneWay}"
                                       Foreground="Red" FontSize="12"
                                       Visibility="{x:Bind ViewModel.CloudAuthError, Mode=OneWay, Converter={StaticResource StringToVisibilityConverter}}"/>
                        </StackPanel>
                    </Border>

                    <Button Content="Next"
                            HorizontalAlignment="Stretch"
                            Style="{StaticResource AccentButtonStyle}"
                            Command="{x:Bind ViewModel.NextStepCommand}"
                            IsEnabled="{x:Bind ViewModel.CanAdvanceFromStorageStep, Mode=OneWay}"/>

                    <Button Content="Back"
                            HorizontalAlignment="Stretch"
                            Command="{x:Bind ViewModel.PreviousStepCommand}"/>

                </StackPanel>

                <!-- ════════════ STEP 2: Password Creation ════════════ -->
                <StackPanel Spacing="16"
                            Visibility="{x:Bind ViewModel.CurrentStep, Mode=OneWay, Converter={StaticResource StepToVisibilityConverter}, ConverterParameter=2}">

                    <TextBlock Text="Create Your Master Password"
                               FontSize="24" FontWeight="Bold"
                               Foreground="{StaticResource QuantumVioletBrush}"/>

                    <TextBlock Text="This password protects your vault. It cannot be recovered if lost."
                               TextWrapping="Wrap" Opacity="0.7"/>

                    <!-- Vault Name -->
                    <TextBox Header="Vault Name"
                             PlaceholderText="e.g., My Vault"
                             Text="{x:Bind ViewModel.VaultName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                             MaxLength="50"/>

                    <!-- Vault Folder (local only) -->
                    <StackPanel Spacing="4"
                                Visibility="{x:Bind ViewModel.IsLocalBackend, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                        <TextBlock Text="Vault Folder" FontWeight="SemiBold" FontSize="14"/>
                        <Grid ColumnSpacing="8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="{x:Bind ViewModel.VaultFolderPath, Mode=OneWay}"
                                       FontSize="12" Opacity="0.6" VerticalAlignment="Center"
                                       TextTrimming="CharacterEllipsis"/>
                            <Button Grid.Column="1" Content="Browse..." Click="BrowseVaultFolder_Click"/>
                        </Grid>
                    </StackPanel>

                    <PasswordBox x:Name="PasswordBox"
                                 Header="Create Master Password"
                                 PlaceholderText="Enter a strong password"
                                 PasswordChanged="PasswordBox_PasswordChanged"/>

                    <!-- Entropy Meter -->
                    <StackPanel Spacing="8">
                        <ProgressBar x:Name="EntropyBar"
                                     Value="{x:Bind ViewModel.EntropyBits, Mode=OneWay}"
                                     Maximum="100" Minimum="0" Height="8"/>

                        <TextBlock FontSize="13">
                            <Run FontWeight="SemiBold" Text="{x:Bind ViewModel.EntropyBits, Mode=OneWay, Converter={StaticResource DoubleToIntStringConverter}}"/>
                            <Run Text=" bits - "/>
                            <Run Text="{x:Bind ViewModel.StrengthLabel, Mode=OneWay}"/>
                        </TextBlock>

                        <TextBlock FontSize="12" Opacity="0.6">
                            <Run Text="Time to crack: "/>
                            <Run Text="{x:Bind ViewModel.TimeToCrack, Mode=OneWay}"/>
                        </TextBlock>
                    </StackPanel>

                    <!-- Password Hint -->
                    <TextBox Header="Password Hint (Optional)"
                             PlaceholderText="e.g., Name of first pet + birth year"
                             Text="{x:Bind ViewModel.PasswordHint, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                             MaxLength="100"/>

                    <Button Content="Create Vault &amp; Continue"
                            HorizontalAlignment="Stretch"
                            Style="{StaticResource AccentButtonStyle}"
                            Command="{x:Bind ViewModel.CreateVaultCommand}"
                            IsEnabled="{x:Bind ViewModel.IsPasswordValid, Mode=OneWay}"/>

                    <Button Content="Back"
                            HorizontalAlignment="Stretch"
                            Command="{x:Bind ViewModel.PreviousStepCommand}"/>

                    <!-- Loading -->
                    <ProgressRing IsActive="{x:Bind ViewModel.IsCreatingVault, Mode=OneWay}"
                                  Width="32" Height="32"
                                  HorizontalAlignment="Center"/>
                </StackPanel>

                <!-- ════════════ STEP 3: Recovery Kit ════════════ -->
                <StackPanel Spacing="16"
                            Visibility="{x:Bind ViewModel.CurrentStep, Mode=OneWay, Converter={StaticResource StepToVisibilityConverter}, ConverterParameter=3}">

                    <TextBlock Text="Save Your Recovery Information"
                               FontSize="24" FontWeight="Bold"
                               Foreground="{StaticResource QuantumVioletBrush}"/>

                    <!-- Warning Banner -->
                    <InfoBar Severity="Warning" IsOpen="True" IsClosable="False"
                             Title="CRITICAL: Store This Securely"
                             Message="This recovery kit helps you restore access if you forget details. Without your password, your vault cannot be recovered (true zero-knowledge security)."/>

                    <!-- Recovery Kit Display -->
                    <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                            BorderThickness="1" CornerRadius="8" Padding="20">
                        <TextBlock Text="{x:Bind ViewModel.RecoveryKitText, Mode=OneWay}"
                                   FontFamily="Consolas"
                                   FontSize="12"
                                   IsTextSelectionEnabled="True"
                                   TextWrapping="Wrap"/>
                    </Border>

                    <!-- Export Options -->
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <Button Command="{x:Bind ViewModel.CopyRecoveryKitCommand}">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <FontIcon Glyph="&#xE8C8;" FontSize="16"/>
                                <TextBlock Text="Copy to Clipboard"/>
                            </StackPanel>
                        </Button>
                        <Button Click="OnSaveRecoveryKitClick">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <FontIcon Glyph="&#xE74E;" FontSize="16"/>
                                <TextBlock Text="Save as Text File"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>

                    <!-- Notification bar for copy/save feedback -->
                    <InfoBar x:Name="RecoveryNotification"
                             Severity="Success" IsOpen="False" IsClosable="True"/>

                    <!-- Checkpoint -->
                    <CheckBox Content="I have saved this recovery kit to a secure location"
                              IsChecked="{x:Bind ViewModel.HasAcknowledgedRisk, Mode=TwoWay}"/>

                    <Button Content="Finish Setup"
                            HorizontalAlignment="Stretch"
                            Style="{StaticResource AccentButtonStyle}"
                            Command="{x:Bind ViewModel.FinishSetupCommand}"
                            IsEnabled="{x:Bind ViewModel.CanFinish, Mode=OneWay}"/>
                </StackPanel>

                <!-- Error Message -->
                <TextBlock Text="{x:Bind ViewModel.ErrorMessage, Mode=OneWay}"
                           Foreground="Red" FontSize="12" HorizontalAlignment="Center"
                           Visibility="{x:Bind ViewModel.ErrorMessage, Mode=OneWay, Converter={StaticResource StringToVisibilityConverter}}"/>

            </StackPanel>
        </Grid>
    </ScrollViewer>
</Page>
