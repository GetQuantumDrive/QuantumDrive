# Build outputs
bin/
obj/
out/

# Visual Studio
.vs/
*.suo
*.user
*.userosscache
*.sln.docstates
*.VC.db
*.VC.opendb
*.opensdf
*.sdf
*.cachefile
*.aps

# Rider
.idea/
*.DotSettings.user

# VS Code
.vscode/

# NuGet
*.nupkg
*.snupkg
**/packages/
!**/packages/build/
project.lock.json
project.fragment.lock.json
artifacts/

# Test results
TestResults/
coverage/
*.trx
*.coverage
*.coveragexml

# Installer build outputs
publish/
installer/*.msi
installer/*.wixpdb

# MSIX / AppX packaging
AppPackages/
BundleArtifacts/
*.msix
*.msixbundle
*.appx
*.appxbundle
*.appxupload
_Pvt_Extensions/

# Code signing — never commit private keys or certificates
*.pfx
*.p12
*.cer
*.key

# Windows OS files
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# macOS
.DS_Store
.AppleDouble
.LSOverride

# Logs and temporaries
*.log
*.tmp
*.temp
crash.dmp

# Publish profiles (contain environment-specific paths)
**/Properties/PublishProfiles/

# Claude Code local settings
.claude/settings.local.json

# Vault data files — encrypted drive content should never be committed
*.qd
